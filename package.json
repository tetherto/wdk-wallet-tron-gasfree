{
  "name": "@tetherto/wdk-wallet-tron-gasfree",
  "version": "1.0.0-beta.7",
  "description": "A simple package to manage BIP-32 wallets for the tron blockchain with gasfree features.",
  "keywords": [
    "wdk",
    "wallet",
    "bip-32",
    "tron",
    "gasfree"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git://github.com/tetherto/wdk-wallet-tron-gasfree.git"
  },
  "main": "index.js",
  "type": "module",
  "types": "./types",
  "scripts": {
    "build:types": "tsc",
    "lint": "standard",
    "lint:fix": "standard --fix --env jest",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand --testPathIgnorePatterns=testnet",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand --coverage --testPathIgnorePatterns=testnet",
    "test:testnet": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand --testPathPattern=testnet"
  },
  "dependencies": {
    "@noble/curves": "1.9.7",
    "@noble/hashes": "1.8.0",
    "@noble/secp256k1": "2.3.0",
    "@tetherto/wdk-wallet": "1.0.0-beta.10",
    "@tetherto/wdk-wallet-tron": "1.0.0-beta.6",
    "bare-node-runtime": "1.4.0",
    "tronweb": "6.3.0"
  },
  "devDependencies": {
    "cross-env": "7.0.3",
    "jest": "29.7.0",
    "standard": "17.1.2",
    "typescript": "5.8.3"
  },
  "overrides": {
    "axios": "1.18.0"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "bare": "./bare.js",
      "default": "./index.js"
    },
    "./package": {
      "default": "./package.json"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "standard": {
    "ignore": [
      "bare.js",
      "tests/**/*.js"
    ]
  }
}
